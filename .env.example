# Core trading config
JUPITER_SENTINEL_LIVE=false
JUPITER_SENTINEL_ENTRY_AMOUNT_SOL=0.25
JUPITER_SENTINEL_ENTER_ON=down
JUPITER_SENTINEL_MAX_OPEN_POSITIONS=3
JUPITER_SENTINEL_INTERVAL_SECS=60
JUPITER_SENTINEL_ITERATIONS=
JUPITER_SENTINEL_FOREGROUND=false

# Runtime paths
JUPITER_SENTINEL_RUNTIME_DIR=
JUPITER_SENTINEL_STATE_FILE=

# Healthcheck server
JUPITER_SENTINEL_HEALTHCHECK_ENABLED=false
JUPITER_SENTINEL_HEALTH_HOST=0.0.0.0
JUPITER_SENTINEL_HEALTH_PORT=8000
JUPITER_SENTINEL_HEALTH_STALE_AFTER_SECS=300

# Chain and execution
JUP_API_KEY=
SOLANA_PUBLIC_KEY=
SOLANA_PRIVATE_KEY_PATH=
ETHEREUM_RPC_URL=
PROFIT_LOCK_PCT=0.5

# Optional bridge API base URL overrides
WORMHOLESCAN_BASE_URL=
DEBRIDGE_STATS_BASE_URL=
MAYAN_EXPLORER_BASE_URL=

# Optional whale watcher mapping: {"walletAddress":"label"}
WHALE_WATCHER_EXCHANGES_JSON=

# Optional Telegram notifications
